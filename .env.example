# PostgreSQL connection (required)
# Docker Compose uses port 5432. If another PostgreSQL instance already uses 5432 locally, use 5433 instead.
DATABASE_URL=postgresql://hds:hds_dev_password@localhost:5432/hds_store

# JWT authentication (required)
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-characters
JWT_EXPIRES_IN=7d

# Initialize all tables + seed data: npm run db:setup  (or npm run db:init if DB already exists)

# Optional: run schema + seed on app startup (default true in development)
# DB_AUTO_INIT=true

# SMTP (optional — for password reset & notifications)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=
